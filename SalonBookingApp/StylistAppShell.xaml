<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:SalonBookingApp.Views"
       x:Class="SalonBookingApp.StylistAppShell"
       Shell.TabBarBackgroundColor="#EAB8C1"
       Shell.TabBarForegroundColor="#000000"
       Shell.TabBarTitleColor="#000000"
       Shell.TabBarUnselectedColor="#8E8E93">

    <TabBar>
        <Tab Icon="appointments.png">
            <ShellContent ContentTemplate="{DataTemplate views:StylistCalendarPage}" />
        </Tab>
        <Tab Icon="user.png">
            <ShellContent ContentTemplate="{DataTemplate views:StylistProfilePage}" />
        </Tab>
    </TabBar>
</Shell>