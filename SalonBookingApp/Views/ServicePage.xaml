<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SalonBookingApp.Views.ServicePage"
             Title="Lista Servicii">
    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="ToolbarAddService" Text="+" Clicked="OnItemAdded" />
    </ContentPage.ToolbarItems>

    <Grid Padding="10">
        <CollectionView x:Name="listView" SelectionMode="Single" SelectionChanged="OnSelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="10">
                        <Label Text="{Binding Name}" FontSize="Medium" FontAttributes="Bold" />
                        <Label Text="{Binding Price, StringFormat='Preț: {0} RON'}" FontSize="Small" TextColor="Gray" />
                        <Label Text="{Binding Duration, StringFormat='Durata: {0} min'}" FontSize="Small" TextColor="Gray" />
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>