<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SalonBookingApp.Views.ServiceEntryPage"
             Title="Detalii Serviciu">

    <VerticalStackLayout Spacing="20" Padding="20">
        <Label Text="Nume Serviciu:" FontAttributes="Bold"/>
        <Entry Text="{Binding Name}" Placeholder="Ex: Tuns Bărbați" />

        <Label Text="Durata (minute):" FontAttributes="Bold"/>
        <Entry Text="{Binding Duration}" Placeholder="Ex: 30" Keyboard="Numeric" />

        <Label Text="Preț (RON):" FontAttributes="Bold"/>
        <Entry Text="{Binding Price}" Placeholder="Ex: 50" Keyboard="Numeric" />

        <Button Text="Salvează" Clicked="OnSaveButtonClicked" 
                BackgroundColor="Blue" TextColor="White"/>

        <Button Text="Șterge" Clicked="OnDeleteButtonClicked" 
                BackgroundColor="Red" TextColor="White"/>
    </VerticalStackLayout>
</ContentPage>