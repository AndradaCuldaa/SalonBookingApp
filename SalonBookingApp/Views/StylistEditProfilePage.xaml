<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:SalonBookingApp.Resources.Strings"
             x:Class="SalonBookingApp.Views.StylistEditProfilePage"
             Title="{x:Static strings:AppResources.ProfileDetails}"
             BackgroundColor="White">

    <Grid>
        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="20" Padding="20">

                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Border HeightRequest="120" WidthRequest="120" 
                            StrokeThickness="4" Stroke="White"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="60"/>
                        </Border.StrokeShape>

                        <Image x:Name="ImageProfilePic" 
                               Aspect="AspectFill"/>
                    </Border>

                    <Button Text="{x:Static strings:AppResources.ChangePhoto}"
                            Clicked="OnChangePhotoClicked"
                            BackgroundColor="Transparent"
                            TextColor="#EAB8C1"
                            FontFamily="Lora"
                            FontSize="14"/>
                </VerticalStackLayout>

                <Entry Text="{Binding FirstName}" 
                       Placeholder="{x:Static strings:AppResources.FirstNamePlaceholder}" 
                       FontFamily="Lora"/>

                <Entry Text="{Binding LastName}" 
                       Placeholder="{x:Static strings:AppResources.LastNamePlaceholder}" 
                       FontFamily="Lora"/>

                <Entry Text="{Binding Specialization}" 
                       Placeholder="{x:Static strings:AppResources.SpecialtyPlaceholder}" 
                       FontFamily="Lora"/>

                <Entry Text="{Binding Username}" 
                       Placeholder="{x:Static strings:AppResources.UserPlaceholder}" 
                       FontFamily="Lora"/>

                <Entry Text="{Binding Password}" 
                       Placeholder="{x:Static strings:AppResources.PassPlaceholder}" 
                       IsPassword="True"
                       FontFamily="Lora"/>

                <Button Text="{x:Static strings:AppResources.BtnSave}"
                        Clicked="OnSaveClicked"
                        BackgroundColor="#EAB8C1"
                        TextColor="White"
                        CornerRadius="20"
                        FontFamily="Lora"
                        Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="ContextMenuOverlay" IsVisible="False" ZIndex="10">
            <BoxView BackgroundColor="Black" Opacity="0.01">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCancelClicked" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Frame x:Name="ContextMenuFrame"
                   BackgroundColor="#2D2D2D"
                   CornerRadius="14"
                   Padding="0"
                   WidthRequest="250"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   Scale="0"
                   HasShadow="True">

                <VerticalStackLayout>
                    <Grid ColumnDefinitions="*, Auto" Padding="15,12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOptionSelected" CommandParameter="Library" />
                        </Grid.GestureRecognizers>
                        <Label Text="{x:Static strings:AppResources.PhotoLibrary}" TextColor="White" VerticalOptions="Center" FontFamily="Lora"/>
                        <Image Source="gallery.png" Grid.Column="1" HeightRequest="20" WidthRequest="20"/>
                    </Grid>
                    <BoxView HeightRequest="0.5" Color="#444444" />

                    <Grid ColumnDefinitions="*, Auto" Padding="15,12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOptionSelected" CommandParameter="Camera" />
                        </Grid.GestureRecognizers>
                        <Label Text="{x:Static strings:AppResources.TakePhoto}" TextColor="White" VerticalOptions="Center" FontFamily="Lora"/>
                        <Image Source="camera.png" Grid.Column="1" HeightRequest="20" WidthRequest="20"/>
                    </Grid>
                    <BoxView HeightRequest="0.5" Color="#444444" />

                    <Grid ColumnDefinitions="*, Auto" Padding="15,12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOptionSelected" CommandParameter="Files" />
                        </Grid.GestureRecognizers>
                        <Label Text="{x:Static strings:AppResources.ChooseFile}" TextColor="White" VerticalOptions="Center" FontFamily="Lora"/>
                        <Image Source="document.png" Grid.Column="1" HeightRequest="20" WidthRequest="20"/>
                    </Grid>
                    <BoxView HeightRequest="0.5" Color="#444444" />

                    <Grid ColumnDefinitions="*, Auto" Padding="15,12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOptionSelected" CommandParameter="Remove" />
                        </Grid.GestureRecognizers>
                        <Label Text="{x:Static strings:AppResources.RemovePhoto}" TextColor="#FF3B30" VerticalOptions="Center" FontFamily="Lora"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>