<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:SalonBookingApp.Resources.Strings"
             x:Class="SalonBookingApp.Views.AppointmentListPage"
             Title="{x:Static strings:AppResources.AppointsTab}"
             BackgroundColor="#F8F8F8">

    <Grid>
        <Grid Padding="20,10,20,0">
            <CollectionView x:Name="listView"
                            SelectionMode="Single"
                            SelectionChanged="OnListItemSelected">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White"
                                Stroke="#EAB8C1"
                                StrokeThickness="2"
                                Padding="15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,5" Opacity="0.1" Radius="10" />
                            </Border.Shadow>

                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Border Grid.Column="0" 
                                        BackgroundColor="#FFF0F2" 
                                        HeightRequest="50" 
                                        WidthRequest="50" 
                                        StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10" />
                                    </Border.StrokeShape>
                                    <Label Text="📅" HorizontalOptions="Center" VerticalOptions="Center" FontSize="20" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Margin="15,0" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding AppointmentDate, StringFormat='{0:dd MMMM yyyy}'}" 
                                           FontAttributes="Bold" 
                                           FontSize="16" 
                                           TextColor="#333333" 
                                           FontFamily="Lora" />

                                    <Label Text="{Binding AppointmentDate, StringFormat='{0:HH:mm}'}" 
                                           FontSize="14" 
                                           TextColor="#EAB8C1" 
                                           FontAttributes="Bold" 
                                           FontFamily="Lora" />
                                </VerticalStackLayout>

                                <Label Grid.Column="2" 
                                       Text="➔" 
                                       TextColor="#D1D1D1" 
                                       VerticalOptions="Center" 
                                       FontSize="18" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <BoxView HeightRequest="80" BackgroundColor="Transparent" />
                </CollectionView.Footer>
            </CollectionView>
        </Grid>

        <Button Text="+"
                BackgroundColor="#EAB8C1"
                TextColor="White"
                FontSize="30"
                FontAttributes="Bold"
                CornerRadius="30"
                HeightRequest="60"
                WidthRequest="60"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="25"
                Clicked="OnItemAdded">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="0,4" Opacity="0.3" Radius="8" />
            </Button.Shadow>
        </Button>
    </Grid>
</ContentPage>