<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SalonBookingApp.Views.NewAppointmentPage"
             Title="Adauga Programare">
    <ScrollView>
        <StackLayout Padding="20" Spacing="20">
            <Label Text="Completează detaliile" FontSize="20" FontAttributes="Bold" TextColor="#3F51B5" HorizontalOptions="Center"/>

            <DatePicker x:Name="DatePickerData" MinimumDate="{Binding Source={x:Static sys:DateTime.Today}}" 
                        xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
            <TimePicker x:Name="TimePickerOra" />

            <Label Text="Stilist:" TextColor="Black"/>
            <Picker x:Name="PickerStilist" Title="Alege stilistul" ItemDisplayBinding="{Binding FullName}" />

            <Label Text="{Binding Source={x:Reference PickerServiciu}, Path=SelectedItem.Duration, StringFormat='Durată estimată: {0} minute'}"
                    TextColor="Gray"
                    FontSize="12"
                    IsVisible="{Binding Source={x:Reference PickerServiciu}, Path=SelectedItem, Converter={StaticResource NullToBoolConverter}}" />
            <Label Text="{Binding Source={x:Reference PickerServiciu}, Path=SelectedItem.Price, StringFormat='Preț: {0} RON'}"
       TextColor="#2ecc71"
       FontSize="14"
       FontAttributes="Bold"
       IsVisible="{Binding Source={x:Reference PickerServiciu}, Path=SelectedItem, Converter={StaticResource NullToBoolConverter}}" />
            <Picker x:Name="PickerServiciu" Title="Alege serviciul" ItemDisplayBinding="{Binding Name}" />

            <Button Text="Salvează Programarea" Clicked="OnSaveClicked"
                    BackgroundColor="#3F51B5" TextColor="White" CornerRadius="10"/>
        </StackLayout>
    </ScrollView>
</ContentPage>