<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:SalonBookingApp.Resources.Strings"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="SalonBookingApp.Views.AccountPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#EAB8C1"
             ios:Page.UseSafeArea="False">
    <Grid>
        <Image Source="salon.jpeg" 
               Aspect="AspectFill" 
               HorizontalOptions="Fill" 
               VerticalOptions="Fill" />

        <BoxView BackgroundColor="Black" Opacity="0.35" />

        <ScrollView VerticalScrollBarVisibility="Never">
            <Grid Padding="0,-90,0,0">
                <VerticalStackLayout Spacing="0">

                    <VerticalStackLayout HeightRequest="400" 
                                         VerticalOptions="Center" 
                                         Spacing="15" 
                                         Padding="0,150,0,0">
                        <Border HeightRequest="130" 
                                WidthRequest="130" 
                                StrokeThickness="4" 
                                Stroke="#EAB8C1"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="65"/>
                            </Border.StrokeShape>
                            <Image x:Name="ImageProfilePic" Source="profile_placeholder.png" Aspect="AspectFill"/>
                        </Border>

                        <Label x:Name="LabelUserName" 
                               TextColor="White" 
                               FontSize="30" 
                               FontAttributes="Bold" 
                               HorizontalOptions="Center" 
                               FontFamily="Lora">
                            <Label.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Opacity="0.6" Radius="5"/>
                            </Label.Shadow>
                        </Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="15" Padding="20" Margin="0,0,0,50">
                        <Border BackgroundColor="White" Stroke="#EAB8C1" StrokeThickness="4" Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="25"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,10" Opacity="0.1" Radius="20"/>
                            </Border.Shadow>
                            <VerticalStackLayout>
                                <Grid ColumnDefinitions="60, *, Auto" Padding="15,20" BackgroundColor="White">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnEditProfileTapped"/>
                                    </Grid.GestureRecognizers>
                                    <Image Source="user.png" HeightRequest="24" WidthRequest="24"/>
                                    <Label Grid.Column="1" Text="{x:Static strings:AppResources.EditProfile}" VerticalOptions="Center" FontSize="17"  FontAttributes="Bold"  FontFamily="Lora" TextColor="Black"/>
                                    <Label Grid.Column="2" Text="➔" TextColor="Black" FontSize="20"/>
                                </Grid>
                                <BoxView HeightRequest="1" BackgroundColor="#F5F5F5" Margin="60,0,20,0"/>
                                <Grid ColumnDefinitions="60, *, Auto" Padding="15,20" BackgroundColor="White">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnAccountInfoTapped"/>
                                    </Grid.GestureRecognizers>
                                    <Image Source="info.png" HeightRequest="24" WidthRequest="24"/>
                                    <Label Grid.Column="1" Text="{x:Static strings:AppResources.AccountInfo}" VerticalOptions="Center" FontSize="17"  FontAttributes="Bold"  FontFamily="Lora" TextColor="Black"/>
                                    <Label Grid.Column="2" Text="➔" TextColor="Black" FontSize="20"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <Border BackgroundColor="White" Stroke="#EAB8C1" StrokeThickness="4" Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="25"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,10" Opacity="0.1" Radius="20"/>
                            </Border.Shadow>
                            <VerticalStackLayout>
                                <Grid ColumnDefinitions="60, *, Auto" Padding="15,20" BackgroundColor="White">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                                    </Grid.GestureRecognizers>
                                    <Image Source="language.png" HeightRequest="24" WidthRequest="24"/>
                                    <Label Grid.Column="1" Text="{x:Static strings:AppResources.LanguageTitle}" VerticalOptions="Center" FontSize="17"  FontAttributes="Bold"  FontFamily="Lora" TextColor="Black"/>
                                    <Label Grid.Column="2" Text="➔" TextColor="Black" FontSize="20"/>
                                </Grid>
                                <BoxView HeightRequest="1" BackgroundColor="#F5F5F5" Margin="60,0,20,0"/>
                                <Grid ColumnDefinitions="60, *, Auto" Padding="15,20" BackgroundColor="White">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignOutClicked"/>
                                    </Grid.GestureRecognizers>
                                    <Image Source="info.png" HeightRequest="24" WidthRequest="24" Opacity="0.6"/>
                                    <Label Grid.Column="1" Text="{x:Static strings:AppResources.SignOut}" VerticalOptions="Center" TextColor="#FF3B30" FontSize="17" FontAttributes="Bold" FontFamily="Lora" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>