<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:SalonBookingApp.Resources.Strings"
             x:Class="SalonBookingApp.Views.SubscriptionsPage"
             Title="{x:Static strings:AppResources.MembershipsTitle}"
             BackgroundColor="#F8F8F8">

    <Grid RowDefinitions="Auto, Auto, *">

        <VerticalStackLayout Grid.Row="0" Padding="25,20,25,10" Spacing="5">
            <Label Text="{x:Static strings:AppResources.PremiumMemberships}" FontSize="26" FontAttributes="Bold" TextColor="#1C1C1E" FontFamily="Lora"/>
            <Label Text="{x:Static strings:AppResources.ChoosePerfectPlan}" FontSize="15" TextColor="#8E8E93" FontFamily="Lora"/>
        </VerticalStackLayout>

        <Grid Grid.Row="1" Margin="25,10,25,15" HeightRequest="45">
            <Frame BackgroundColor="#EEEEEE" CornerRadius="22" HasShadow="False" Padding="2" BorderColor="Transparent"/>
            <Grid ColumnDefinitions="*, *">
                <Frame x:Name="TabLunare" Grid.Column="0" BackgroundColor="White" CornerRadius="20" HasShadow="True" Padding="0" BorderColor="Transparent">
                    <Label x:Name="TextLunare" Text="{x:Static strings:AppResources.TabMonthly}" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="Black" FontFamily="Lora"/>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabLunareTapped" />
                    </Frame.GestureRecognizers>
                </Frame>

                <Frame x:Name="TabSedinte" Grid.Column="1" BackgroundColor="Transparent" CornerRadius="20" HasShadow="False" Padding="0" BorderColor="Transparent">
                    <Label x:Name="TextSedinte" Text="{x:Static strings:AppResources.TabSessions}" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#8E8E93" FontFamily="Lora"/>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabSedinteTapped" />
                    </Frame.GestureRecognizers>
                </Frame>
            </Grid>
        </Grid>

        <CollectionView x:Name="ListaLunare" Grid.Row="2" Margin="20,0,20,20" IsVisible="True">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="20" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="{Binding CardColor}" CornerRadius="20" Padding="20" HasShadow="True" BorderColor="Transparent">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="{Binding Name}" FontSize="24" FontAttributes="Bold" TextColor="{Binding TextColor}" FontFamily="Lora"/>
                                <Label Grid.Column="1" Text="{Binding Price, StringFormat='{0} RON'}" FontSize="22" FontAttributes="Bold" TextColor="{Binding TextColor}" VerticalOptions="Center" FontFamily="Lora"/>
                            </Grid>
                            <Label Text="{Binding Concept}" FontSize="14" FontAttributes="Italic" TextColor="{Binding TextColor}" Opacity="0.8" FontFamily="Lora" Margin="0,-5,0,10"/>

                            <BoxView HeightRequest="1" BackgroundColor="{Binding TextColor}" Opacity="0.2" Margin="0,0,0,10"/>

                            <Label Text="{x:Static strings:AppResources.WhatsIncluded}" FontAttributes="Bold" TextColor="{Binding TextColor}" FontSize="15" FontFamily="Lora"/>
                            <Label Text="{Binding Inclusions}" TextColor="{Binding TextColor}" FontSize="14" LineHeight="1.3" FontFamily="Lora"/>

                            <Label Text="{x:Static strings:AppResources.ExtraPerks}" FontAttributes="Bold" TextColor="{Binding TextColor}" FontSize="15" Margin="0,10,0,0" FontFamily="Lora"/>
                            <Label Text="{Binding Perks}" TextColor="{Binding TextColor}" FontSize="14" LineHeight="1.3" FontFamily="Lora"/>

                            <Button Text="{x:Static strings:AppResources.ChooseSubscriptionBtn}" Clicked="OnBuyMonthlyPlanClicked" BackgroundColor="White" TextColor="Black" FontAttributes="Bold" CornerRadius="15" HeightRequest="45" Margin="0,15,0,0" FontFamily="Lora"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <CollectionView x:Name="ListaSedinte" Grid.Row="2" Margin="20,0,20,20" IsVisible="False">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="White" CornerRadius="20" Padding="20" HasShadow="True" BorderColor="#EAB8C1">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto">
                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="Black" FontFamily="Lora"/>
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Price, StringFormat='{0} RON'}" FontSize="18" FontAttributes="Bold" TextColor="#EAB8C1" FontFamily="Lora"/>

                            <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Description}" FontSize="14" TextColor="Gray" Margin="0,10,0,15" LineHeight="1.3" FontFamily="Lora"/>

                            <Button Grid.Row="2" Grid.ColumnSpan="2" Text="{x:Static strings:AppResources.BuyPackageBtn}" Clicked="OnBuySessionPackageClicked" BackgroundColor="#EAB8C1" TextColor="Black" FontAttributes="Bold" CornerRadius="15" HeightRequest="45" FontFamily="Lora"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>