<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SalonBookingApp.Views.AboutPage"
             Title="Despre Noi"
             BackgroundColor="#F5F5F5">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
               

                <Label Text="Bine ai venit la SalonBooking"
                       TextColor="#2D3436"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />

                <Label Text="Răsfațul tău la un click distanță"
                       TextColor="#636E72"
                       FontSize="16"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Button Text="Fă o Programare Acum"
                    Clicked="OnProgrameazaClicked"
                    BackgroundColor="#6C5CE7"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="25"
                    HeightRequest="50"
                    Margin="0,10,0,10"/>

            <Label Text="Cum funcționează?"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,10,0,5"
                   TextColor="#2D3436"/>

            <Frame CornerRadius="15" HasShadow="True" BorderColor="Transparent" BackgroundColor="White">
                <VerticalStackLayout Spacing="5">
                    <Label Text="📱 Booking Online Rapid" 
                           FontSize="18" FontAttributes="Bold" TextColor="#6C5CE7"/>
                    <Label Text="SalonBooking este aplicația modernă care te scapă de apelurile telefonice. Verifici disponibilitatea în timp real și te programezi când vrei tu."
                           TextColor="#636E72"/>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="15" HasShadow="True" BorderColor="Transparent" BackgroundColor="White">
                <VerticalStackLayout Spacing="5">
                    <Label Text="✂️ Alege-ți Stilistul" 
                           FontSize="18" FontAttributes="Bold" TextColor="#6C5CE7"/>
                    <Label Text="Ai un stilist preferat? În aplicația noastră poți selecta exact persoana pe mâna căreia vrei să te lași pentru un look perfect."
                           TextColor="#636E72"/>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="15" HasShadow="True" BorderColor="Transparent" BackgroundColor="White">
                <VerticalStackLayout Spacing="5">
                    <Label Text="💅 Servicii Diversificate" 
                           FontSize="18" FontAttributes="Bold" TextColor="#6C5CE7"/>
                    <Label Text="De la tuns și vopsit, până la manichiură și cosmetică. Selectează serviciul dorit din lista noastră completă."
                           TextColor="#636E72"/>
                </VerticalStackLayout>
            </Frame>

            <BoxView HeightRequest="20" />

            <Button Text="Ieși din Cont (Log Out)"
                    Clicked="OnLogoutClicked"
                    BackgroundColor="#FAB1A0"
                    TextColor="#D63031"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    Margin="0,0,0,20"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>