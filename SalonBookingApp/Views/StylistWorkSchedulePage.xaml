<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:SalonBookingApp.Resources.Strings"
             x:Class="SalonBookingApp.Views.StylistWorkSchedulePage"
             Title="Program de lucru"
             BackgroundColor="White">

    <Grid>
        <Image Source="salon.jpeg" Aspect="AspectFill" />

        <Grid RowDefinitions="Auto, *, Auto" Padding="20">

            <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,0,0,15">
                <Label Text="Program de lucru" FontSize="24" FontAttributes="Bold" FontFamily="Lora" TextColor="White"/>
                <Label Text="Alege intervalul orar în care clienții pot face programări." FontSize="14" FontFamily="Lora" TextColor="White"/>

                <Border Stroke="#EAB8C1" StrokeThickness="1" BackgroundColor="White" Margin="0,10,0,0" Padding="10,5">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Button Text="&lt;" Clicked="OnPrevWeekClicked" BackgroundColor="Transparent" TextColor="Black" Grid.Column="0"/>
                        <Label x:Name="LabelSaptamana" Text="04 Mai - 10 Mai" VerticalOptions="Center" HorizontalOptions="Center" Grid.Column="1" FontFamily="Lora" FontAttributes="Bold"/>
                        <Button Text="&gt;" Clicked="OnNextWeekClicked" BackgroundColor="Transparent" TextColor="Black" Grid.Column="2"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
                <VerticalStackLayout x:Name="ContainerZile" Spacing="12">
                </VerticalStackLayout>
            </ScrollView>

            <Button Grid.Row="2" 
                    Text="Salvează programul"
                    Clicked="OnSaveScheduleClicked"
                    BackgroundColor="#EAB8C1"
                    TextColor="White"
                    CornerRadius="25"
                    FontFamily="Lora"
                    HeightRequest="50"
                    Margin="0,15,0,0"/>
        </Grid>
    </Grid>
</ContentPage>